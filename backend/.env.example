# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── App ────────────────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173

# ── JWT ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-32-char-random-secret-here

# ── Supabase ───────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# ── AI (needed from Sprint 2) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
FIRECRAWL_API_KEY=fc-...     # get from firecrawl.dev

# ── Twilio (needed from Sprint 7) ─────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_MESSAGING_SERVICE_SID=MG...

# ── Vapi (needed from Sprint 10) ──────────────────────────────
VAPI_API_KEY=...
VAPI_WEBHOOK_SECRET=...

# ── Stripe (needed from Sprint 7) ─────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...

# ── Email (needed from Sprint 6) ──────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=hello@ravira.ai

# ── Redis (needed from Sprint 3) ──────────────────────────────
REDIS_URL=redis://localhost:6379
